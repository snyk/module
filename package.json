{
  "name": "snyk-module",
  "description": "Snyk module helper",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/snyk/module.git"
  },
  "homepage": "https://github.com/snyk/module#readme",
  "bugs": {
    "url": "https://github.com/snyk/module/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsc",
    "lint": "npm run format:check && eslint --cache '{lib,test}/**/*.{js,ts}'",
    "test": "jest",
    "format:check": "prettier --check '{lib,test}/**/*.{js,ts}'",
    "format": "prettier --write '{lib,test}/**/*.{js,ts}'",
    "prepare": "npm run build"
  },
  "author": "Remy Sharp",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/hosted-git-info": "^3.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^16",
    "@typescript-eslint/eslint-plugin": "^2.33.0",
    "@typescript-eslint/parser": "^2.33.0",
    "benny": "^3.6.14",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.11.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "prettier": "^1.19.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "debug": "^4.1.1",
    "hosted-git-info": "^4.0.2"
  }
}
